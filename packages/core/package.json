{
  "name": "@aide/core",
  "version": "0.1.0",
  "description": "Core business logic for Aide - AI Mod Manager",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "handlebars": "^4.7.8",
    "semver": "^7.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/semver": "^7.5.0",
    "@types/handlebars": "^4.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
